# =====================================================
# STRIPE CONFIGURATION
# =====================================================
# Get your keys at: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_seu_publishable_key_aqui
STRIPE_SECRET_KEY=sk_test_seu_secret_key_aqui

# ⚠️ WEBHOOK SECRET NÃO DEVE ESTAR AQUI!
# Configure no Supabase Secrets com: supabase secrets set STRIPE_WEBHOOK_SECRET=whsec_xxx
# NUNCA exponha webhook secret no frontend ou .env commitado
# VITE_STRIPE_WEBHOOK_SECRET=whsec_seu_webhook_secret_aqui  # ❌ REMOVIDO POR SEGURANÇA

# Stripe Price IDs (created when you set up products in Stripe Dashboard)
# Basic Plan
VITE_STRIPE_PRICE_BASIC_MONTHLY=price_xxx
VITE_STRIPE_PRICE_BASIC_YEARLY=price_xxx

# Professional Plan
VITE_STRIPE_PRICE_PROFESSIONAL_MONTHLY=price_xxx
VITE_STRIPE_PRICE_PROFESSIONAL_YEARLY=price_xxx

# Premium Plan
VITE_STRIPE_PRICE_PREMIUM_MONTHLY=price_xxx
VITE_STRIPE_PRICE_PREMIUM_YEARLY=price_xxx

# =====================================================
# PAYMENT CONFIGURATION (OPTIONAL)
# =====================================================
# Provider defaults (rollout can override per tenant em payment_provider_configs)
# Asaas SANDBOX = sem cobranças reais (use conta de testes em https://sandbox.asaas.com)
VITE_SUBSCRIPTION_PROVIDER_DEFAULT=asaas
VITE_BOOKING_PROVIDER_DEFAULT=asaas

# Asaas — IMPORTANTE
# - Cobranças REAIS: API de produção (api.asaas.com) + chave que contém $aact_prod + ASAAS_ENV=production
# - Testes / dev: SEMPRE sandbox + chave da conta SANDBOX ($aact_… sem “prod”) + ASAAS_ENV=sandbox
# - As chaves ASAAS_* abaixo são para referência local; o app chama Edge Functions que leem secrets no Supabase:
#     supabase secrets set ASAAS_ENV=sandbox
#     supabase secrets set ASAAS_API_KEY='cole_aqui_a_chave_SANDBOX'
# - Não commite chave de produção. Não use VITE_* para API key (exporia no bundle).
# - Webhook sandbox: configure no painel Asaas sandbox e: supabase secrets set ASAAS_WEBHOOK_SECRET=...
VITE_ASAAS_ENV=sandbox
ASAAS_ENV=sandbox
ASAAS_API_KEY=$aact_sua_chave_SANDBOX_asaas
# Configure no Supabase Secrets: ASAAS_WEBHOOK_SECRET

# Mercado Pago — webhook signature
# Configure no Supabase Secrets com o segredo gerado em "Your integrations > Webhooks":
#   supabase secrets set MERCADOPAGO_WEBHOOK_SECRET='cole_o_secret_aqui'
# Header validado: x-signature + x-request-id

# For barbershops that want to accept cryptocurrency payments
VITE_PIX_KEY=sua_chave_pix_aqui
VITE_BITCOIN_ADDRESS=seu_endereco_bitcoin_aqui
VITE_BITCOIN_ENABLED=false
VITE_USDT_ADDRESS=seu_endereco_usdt_trc20_aqui
VITE_USDT_ENABLED=false

# =====================================================
# EMAIL CONFIGURATION (Resend)
# =====================================================
# Get your API key at: https://resend.com/api-keys
# IMPORTANT: This is a SECRET KEY - only set in Supabase Secrets, NOT in .env
# RESEND_API_KEY=re_xxx (Set with: supabase secrets set RESEND_API_KEY=re_xxx)

# Email sender (configure domain in Resend Dashboard)
VITE_EMAIL_FROM=noreply@shafar.com.br
VITE_EMAIL_FROM_NAME=Shafar

# =====================================================
# WHATSAPP & SMS (Twilio) - OPTIONAL
# =====================================================
VITE_TWILIO_ACCOUNT_SID=seu_twilio_account_sid_aqui
VITE_TWILIO_AUTH_TOKEN=seu_twilio_auth_token_aqui
VITE_TWILIO_WHATSAPP_NUMBER=+14155238886
VITE_TWILIO_PHONE_NUMBER=+15017122661

# =====================================================
# MONITORING (Sentry) - OPTIONAL
# =====================================================
VITE_SENTRY_DSN=seu_sentry_dsn_aqui
VITE_ENVIRONMENT=development